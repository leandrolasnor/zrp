{
  "rabbit_version": "3.13",
  "users": [
    {
      "name": "guest",
      "password": "guest",
      "tags": "administrator"
    }
  ],
  "vhosts": [
    {
      "name": "/"
    }
  ],
  "permissions": [
    {
      "user": "guest",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "un.dlx",
      "vhost": "/",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "un",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "un.dlx"
      }
    },
    {
      "name": "un.retry",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 5000,
        "x-dead-letter-exchange": "",
        "x-dead-letter-routing-key": "un"
      }
    },
    {
      "name": "un.dead",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "un.parser.error",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "un.dlx",
      "vhost": "/",
      "destination": "un.retry",
      "destination_type": "queue",
      "routing_key": "un"
    },
    {
      "source": "un.dlx",
      "vhost": "/",
      "destination": "un.dead",
      "destination_type": "queue",
      "routing_key": "dead"
    },
    {
      "source": "un.dlx",
      "vhost": "/",
      "destination": "un.parser.error",
      "destination_type": "queue",
      "routing_key": "parser.error"
    }
  ]
}
